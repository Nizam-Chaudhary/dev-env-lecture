{
  "name": "bun-lecture-monorepo",
  "private": true,
  "workspaces": [
    "workspaces/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter @lecture/slidedev dev",
    "build": "bun run --filter @lecture/slidedev build",
    "export": "bun run --filter @lecture/slidedev export",
    "lecture:slides": "bun run --filter @lecture/slidedev dev",
    "lecture:structure:check": "bun run --filter @lecture/project-structure check",
    "lecture:structure:backend:module": "bun run --filter @lecture/project-structure dev:backend:module",
    "lecture:structure:backend:layer": "bun run --filter @lecture/project-structure dev:backend:layer",
    "lecture:runtime:watch": "bun run --filter @lecture/docker-node-backend dev",
    "lecture:runtime:nodemon": "bun run --filter @lecture/docker-node-backend dev:nodemon",
    "lecture:runtime:tsx": "bun run --filter @lecture/docker-node-backend dev:tsx",
    "lecture:runtime:build": "bun run --filter @lecture/docker-node-backend build",
    "lecture:runtime:start": "bun run --filter @lecture/docker-node-backend start",
    "lecture:env:dotenv": "bun run --filter @lecture/docker-node-backend env:dotenv",
    "lecture:env:zod": "bun run --filter @lecture/docker-node-backend env:zod",
    "lecture:env:t3": "bun run --filter @lecture/docker-node-backend env:t3",
    "lecture:debug": "bun run --filter @lecture/docker-node-backend debug",
    "lecture:docker:build": "docker build -t lecture/docker-node-backend ./workspaces/docker-node-backend",
    "lecture:docker:run": "docker run --rm -p 3000:3000 lecture/docker-node-backend",
    "lecture:docker:compose:up": "docker compose up -d",
    "lecture:docker:compose:down": "docker compose down",
    "lecture:terminal:vim": "vim --version",
    "lecture:terminal:nano": "nano --version",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "lint": "oxlint . --ignore-path .gitignore",
    "lint:fix": "oxlint . --fix --ignore-path .gitignore",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check"
  },
  "devDependencies": {
    "oxfmt": "^0.31.0",
    "oxlint": "^1.22.0"
  }
}
