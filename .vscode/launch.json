{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker backend (inspect)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect=9229",
        "--import",
        "tsx",
        "src/index.ts"
      ],
      "cwd": "${workspaceFolder}/workspaces/docker-node-backend",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
