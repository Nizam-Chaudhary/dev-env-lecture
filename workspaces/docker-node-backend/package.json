{
  "name": "@lecture/docker-node-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "dev:nodemon": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "dev:tsx": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "debug": "node --inspect=9229 --import tsx src/index.ts",
    "env:dotenv": "tsx src/examples/env-dotenv.ts",
    "env:zod": "tsx src/examples/env-zod.ts",
    "env:t3": "tsx src/examples/env-t3.ts"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.8",
    "dotenv": "^17.2.4",
    "express": "^4.21.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^24.5.2",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
